# Copy to .env and fill in your values

# External URL exposed by Cloudflare Tunnel (no trailing slash)
SERVER_URL=https://stremio.thehouseofthemaster.pt

# Port the Node.js server listens on (default: 7000)
PORT=7000

# TMDB API key — OBRIGATÓRIO. Converte IMDb → TMDB id para as fontes
# VixSrc/Vidlink. Cria conta grátis em themoviedb.org → Settings → API.
TMDB_API_KEY=

# Cache TTL in milliseconds (default: 300000 = 5 min)
# CACHE_TTL_MS=300000

# Max concurrent scrapes (default: 8)
# MAX_QUEUE=8

# Segment retry attempts (default: 1)
# MAX_SEG_RETRIES=1

# Health check interval in milliseconds (default: 600000 = 10 min)
# Set to 0 to completely disable health checks
# HEALTH_CHECK_INTERVAL_MS=600000

# Optional: Slack/Discord webhook for health alerts
# ALERT_WEBHOOK=

# ── Alertas Telegram ──────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=-1001234567890

# ── Alertas Email (SMTP) ──────────────────────────────────────────
# Para Gmail: SMTP_PASS = App Password (não a password normal)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=teu-email@gmail.com
# SMTP_PASS=app-password-16-chars
# ALERT_EMAIL=destinatario@gmail.com   # default = SMTP_USER

# ── Segurança do proxy HLS (C1) ───────────────────────────────────
# Segredo para assinar os tokens do proxy (HMAC). Gerar com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# PROXY_SECRET=
